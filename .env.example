# Forge 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사한 뒤 값을 채운다 (.env는 gitignore 대상).
#   copy .env.example .env
# run_forge.bat은 .env를 자동 로드한다. forge CLI/서버는 환경변수를 직접 읽는다.
# API 키는 절대 forge.yaml에 직접 쓰지 말 것 — 환경변수 이름만 참조한다 (DESIGN.md §8.3).

# --- Provider API 키 (forge.yaml의 api_key_env와 이름이 일치해야 함) ---

# NVIDIA (무료 티어, 기본 프로바이더) — https://build.nvidia.com 에서 발급
NVIDIA_API_KEY=nvapi-...

# OpenRouter (선택) — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Anthropic (선택) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# --- Forge 게이트웨이 자체 인증 (선택) ---
# 설정하면 /v1/* 요청에 Bearer 키를 요구한다. 로컬 단독 사용이면 비워둬도 됨.
# 외부 바인딩(server.host를 127.0.0.1 외로 변경) 시에는 반드시 설정할 것.
# FORGE_API_KEY=
