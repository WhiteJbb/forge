# Forge 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사한 뒤 값을 채운다 (.env는 gitignore 대상).
#   copy .env.example .env
# forge CLI/서버가 forge.yaml과 같은 디렉터리의 .env를 자동 로드한다 (셸 환경변수가 우선).
# API 키는 절대 forge.yaml에 직접 쓰지 말 것 — 환경변수 이름만 참조한다 (DESIGN.md §8.3).

# --- Provider API 키 ---
# 아래 키를 넣기만 하면 해당 프로바이더가 자동 등록된다 (auto_providers 카탈로그).
# forge.yaml에 같은 이름을 명시하면 그쪽 설정이 우선. 끄려면 forge.yaml에 auto_providers: false.

# NVIDIA (무료 티어, 기본 프로바이더) — https://build.nvidia.com 에서 발급
NVIDIA_API_KEY=nvapi-...

# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Anthropic — https://console.anthropic.com (discovery 불가라 대표 모델 자동 등록)
# ANTHROPIC_API_KEY=sk-ant-...

# 그 외 자동 인식: GROQ_API_KEY / MISTRAL_API_KEY / DEEPSEEK_API_KEY / OPENAI_API_KEY
# Ollama는 OLLAMA_API_BASE=http://localhost:11434 로 활성화

# --- Forge 게이트웨이 자체 인증 (선택) ---
# 설정하면 /v1/* 요청에 Bearer 키를 요구한다. 로컬 단독 사용이면 비워둬도 됨.
# 외부 바인딩(server.host를 127.0.0.1 외로 변경) 시에는 반드시 설정할 것.
# FORGE_API_KEY=
